#!/usr/bin/env python3
# -*- coding: utf-8 -*-

"""Stable executable entrypoint for the PICurv conductor."""

import os
import sys
from pathlib import Path


_INVOKED_PATH = Path(__file__).absolute()
_REAL_PATH = _INVOKED_PATH.resolve()
os.environ["_PICURV_INVOKED_SCRIPT_DIR"] = str(_INVOKED_PATH.parent)
os.environ["_PICURV_SCRIPT_PATH"] = str(_REAL_PATH.parent)


def _find_implementation_root():
    """!
    @brief Find a repository root containing the internal conductor package.
    @return Resolved repository root.
    """
    candidates = [_REAL_PATH.parent.parent]
    configured_root = os.environ.get("PICURV_DIR")
    if configured_root:
        candidates.append(Path(configured_root))
    for path_entry in os.environ.get("PATH", "").split(os.pathsep):
        if not path_entry:
            continue
        path = Path(path_entry)
        candidates.append(path.parent if path.name in {"bin", "picurv_cli"} else path)
    for candidate in candidates:
        if (candidate / "picurv_cli" / "main.py").is_file():
            return candidate
    raise RuntimeError(
        "Unable to locate the PICurv implementation package. "
        "Source etc/picurv.sh or add the PICurv bin directory to PATH."
    )


_IMPLEMENTATION_ROOT = _find_implementation_root()
if str(_IMPLEMENTATION_ROOT) not in sys.path:
    sys.path.insert(0, str(_IMPLEMENTATION_ROOT))

from picurv_cli.main import main


if __name__ == "__main__":
    main()
